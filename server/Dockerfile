FROM node:20-alpine

ARG ETK_API_VERSION=development
ARG ETK_WEB_VERSION=development
ARG ETK_GIT_COMMIT=unknown
ARG ETK_BUILD_TIME=unknown
ARG ETK_RELEASE_CHANNEL=development
ARG ETK_API_IMAGE_REF=
ARG ETK_WEB_IMAGE_REF=

WORKDIR /app

COPY server/package*.json ./
RUN npm ci --omit=dev

COPY server/ ./
COPY deploy/releases.json /app/releases.json

ENV NODE_ENV=production
ENV ETK_API_VERSION=${ETK_API_VERSION}
ENV ETK_WEB_VERSION=${ETK_WEB_VERSION}
ENV ETK_GIT_COMMIT=${ETK_GIT_COMMIT}
ENV ETK_BUILD_TIME=${ETK_BUILD_TIME}
ENV ETK_RELEASE_CHANNEL=${ETK_RELEASE_CHANNEL}
ENV ETK_API_IMAGE_REF=${ETK_API_IMAGE_REF}
ENV ETK_WEB_IMAGE_REF=${ETK_WEB_IMAGE_REF}

EXPOSE 3001

CMD ["npm", "start"]

{
  "uid": "etk-queue-events",
  "title": "Express Trade Kit Queue and Events",
  "tags": ["etk", "queue", "events"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Queued Domain Events",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(etk_domain_events_total{phase=\"queued\"}[5m]))",
          "legendFormat": "queued",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Published Domain Events",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(etk_domain_events_total{phase=\"published\"}[5m]))",
          "legendFormat": "published",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "API Target Health",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "up{job=\"etk_api\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "API Down", "color": "red" },
                "1": { "text": "API Up", "color": "green" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Queue Activity Proxy",
      "gridPos": { "x": 8, "y": 8, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(etk_domain_events_total{phase=~\"queued|published\"}[5m])) by (phase)",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    }
  ]
}

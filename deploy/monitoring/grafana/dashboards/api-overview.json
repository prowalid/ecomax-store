{
  "uid": "etk-api-overview",
  "title": "Express Trade Kit API Overview",
  "tags": ["etk", "api", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "constant",
        "label": "Job",
        "query": "etk_api",
        "current": {
          "selected": true,
          "text": "etk_api",
          "value": "etk_api"
        },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "API Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "up{job=\"$job\"}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "Down", "color": "red" },
                "1": { "text": "Up", "color": "green" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(etk_http_requests_total{job=\"$job\"}[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Status Rates",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(etk_http_requests_total{job=\"$job\"}[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Latency p95",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(etk_http_request_duration_seconds_bucket{job=\"$job\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "In-Flight Requests",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "etk_http_requests_in_flight{job=\"$job\"}",
          "legendFormat": "in-flight",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Domain Events",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(etk_domain_events_total{job=\"$job\"}[5m])) by (phase)",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "HTTP 5xx Share",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(etk_http_requests_total{job=\"$job\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(etk_http_requests_total{job=\"$job\"}[5m])), 0.001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.03 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    }
  ]
}

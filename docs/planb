const Product = require('../../../domain/entities/Product');
const Slug = require('../../../domain/value-objects/Slug');
const ValidationError = require('../../../domain/errors/ValidationError');
const ConflictError = require('../../../domain/errors/ConflictError');

class CreateProduct {
  #productRepo;
  #categoryRepo;
  #cacheService;

  constructor({ productRepository, categoryRepository, cacheService }) {
    this.#productRepo = productRepository;
    this.#categoryRepo = categoryRepository;
    this.#cacheService = cacheService;
  }

  async execute(data) {
    // 1. التحقق من الفئة
    if (data.categoryId) {
      const category = await this.#categoryRepo.findById(data.categoryId);
      if (!category) {
        throw new ValidationError('الفئة المحددة غير موجودة');
      }
    }

    // 2. التحقق من تفرد SKU
    if (data.sku) {
      const exists = await this.#productRepo.existsBySku(data.sku);
      if (exists) {
        throw new ConflictError(`رمز المنتج ${data.sku} مستخدم بالفعل`);
      }
    }

    // 3. توليد slug
    const slug = Slug.fromText(data.name);

    // 4. إنشاء الكيان
    const product = new Product({
      name: data.name,
      slug: slug.value,
      description: data.description,
      price: data.price,
      compareAtPrice: data.compareAtPrice,
      cost: data.cost,
      sku: data.sku,
      stock: data.stock || 0,
      trackStock: data.trackStock,
      categoryId: data.categoryId,
      images: data.images || [],
      isActive: data.isActive,
    });

    // 5. حفظ
    const saved = await this.#productRepo.save(product);

    // 6. مسح الكاش ✅
    await this.#cacheService.invalidatePattern('products:*');

    return saved;
  }
}

module.exports = CreateProduct;

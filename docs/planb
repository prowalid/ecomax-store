#### Value Objects

```javascript
// server/src/domain/value-objects/Money.js

class Money {
  #amount;
  #currency;

  constructor(amount, currency = 'SAR') {
    if (typeof amount !== 'number' || isNaN(amount)) {
      throw new Error('المبلغ يجب أن يكون رقماً صالحاً');
    }
    if (amount < 0) {
      throw new Error('المبلغ لا يمكن أن يكون سالباً');
    }

    // تخزين بالهللة/السنت لتجنب مشاكل الأرقام العشرية
    this.#amount = Math.round(amount * 100);
    this.#currency = currency;
  }

  get value() {
    return this.#amount / 100;
  }

  get currency() {
    return this.#currency;
  }

  add(other) {
    this.#assertSameCurrency(other);
    return new Money((this.#amount + other.#amount) / 100, this.#currency);
  }

  subtract(other) {
    this.#assertSameCurrency(other);
    const result = this.#amount - other.#amount;
    if (result < 0) {
      throw new Error('النتيجة لا يمكن أن تكون سالبة');
    }
    return new Money(result / 100, this.#currency);
  }

  multiply(factor) {
    return new Money((this.#amount * factor) / 100, this.#currency);
  }

  equals(other) {
    return other instanceof Money
      && this.#amount === other.#amount
      && this.#currency === other.#currency;
  }

  isZero() {
    return this.#amount === 0;
  }

  format() {
    return `${this.value.toFixed(2)} ${this.#currency}`;
  }

  toJSON() {
    return { amount: this.value, currency: this.#currency };
  }

  #assertSameCurrency(other) {
    if (!(other instanceof Money)) {
      throw new Error('يجب أن يكون الطرف الآخر من نوع Money');
    }
    if (this.#currency !== other.#currency) {
      throw new Error('لا يمكن إجراء عمليات على عملات مختلفة');
    }
  }
}

module.exports = Money;
```


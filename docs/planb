class Container {
  #instances = new Map();
  #factories = new Map();

  register(name, factory) {
    this.#factories.set(name, factory);
  }

  resolve(name) {
    // Singleton
    if (this.#instances.has(name)) {
      return this.#instances.get(name);
    }

    const factory = this.#factories.get(name);
    if (!factory) {
      throw new Error(`الخدمة "${name}" غير مسجلة في الحاوية`);
    }

    const instance = factory(this);
    this.#instances.set(name, instance);
    return instance;
  }

  async shutdown() {
    const pool = this.#instances.get('pool');
    const cache = this.#instances.get('cacheImpl');
    const queue = this.#instances.get('queueManager');

    if (queue) await queue.shutdown();
    if (cache?.disconnect) await cache.disconnect();
    if (pool) await pool.end();
  }
}

function createContainer() {
  const container = new Container();

  // ==========================================
  // Infrastructure
  // ==========================================

  container.register('pool', () => {
    return new Pool(dbConfig);
  });

  container.register('cacheImpl', () => {
    if (process.env.REDIS_URL || process.env.REDIS_HOST) {
      return new RedisCache(redisConfig);

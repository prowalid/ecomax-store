// server/src/domain/entities/Order.js

const Money = require('../value-objects/Money');
const OrderStatus = require('../value-objects/OrderStatus');

class Order {
  #id;
  #orderNumber;
  #customerId;
  #items;
  #status;
  #subtotal;
  #shippingCost;
  #discount;
  #total;
  #shippingAddress;
  #notes;
  #createdAt;
  #updatedAt;

  constructor({
    id, orderNumber, customerId, items, status,
    subtotal, shippingCost, discount, total,
    shippingAddress, notes, createdAt, updatedAt,
  }) {
    if (!items || items.length === 0) {
      throw new Error('الطلب يجب أن يحتوي على عنصر واحد على الأقل');
    }

    if (!customerId) {
      throw new Error('معرف العميل مطلوب');
    }

    this.#id = id || null;
    this.#orderNumber = orderNumber || Order.#generateOrderNumber();
    this.#customerId = customerId;
    this.#items = items;
    this.#status = status instanceof OrderStatus
      ? status
      : new OrderStatus(status || OrderStatus.PENDING);

    this.#subtotal = subtotal instanceof Money ? subtotal : new Money(subtotal);
    this.#shippingCost = shippingCost instanceof Money
      ? shippingCost
      : new Money(shippingCost || 0);
    this.#discount = discount instanceof Money
      ? discount
      : new Money(discount || 0);

    // حساب الإجمالي
    if (total) {
      this.#total = total instanceof Money ? total : new Money(total);
    } else {
      this.#total = this.#calculateTotal();
    }

    this.#shippingAddress = shippingAddress;
    this.#notes = notes || '';
    this.#createdAt = createdAt || new Date();
    this.#updatedAt = updatedAt || new Date();
  }

  // Getters
  get id() { return this.#id; }
  get orderNumber() { return this.#orderNumber; }
  get customerId() { return this.#customerId; }
  get items() { return [...this.#items]; }
  get status() { return this.#status; }
  get subtotal() { return this.#subtotal; }
  get shippingCost() { return this.#shippingCost; }
  get discount() { return this.#discount; }
  get total() { return this.#total; }
  get shippingAddress() { return this.#shippingAddress; }
  get notes() { return this.#notes; }
  get createdAt() { return this.#createdAt; }

  // ✅ سلوكيات الدومين

  changeStatus(newStatus) {
    const previous = this.#status.value;
    this.#status = this.#status.transitionTo(newStatus);
    this.#updatedAt = new Date();

    // إرجاع معلومات التغيير لأجل الأحداث
    return {
      orderId: this.#id,
      orderNumber: this.#orderNumber,
      previousStatus: previous,
      newStatus: this.#status.value,
    };
  }

  cancel(reason) {
    if (this.#status.isFinal()) {
      throw new Error('لا يمكن إلغاء طلب في حالته النهائية');
    }
    this.changeStatus(OrderStatus.CANCELLED);
    this.#notes = reason
      ? `${this.#notes}\nسبب الإلغاء: ${reason}`.trim()
      : this.#notes;
  }

  isPaid() {
    return [
      OrderStatus.CONFIRMED,
      OrderStatus.PROCESSING,
      OrderStatus.SHIPPED,
      OrderStatus.DELIVERED,
    ].includes(this.#status.value);
  }

  canBeEdited() {
    return [OrderStatus.PENDING, OrderStatus.CONFIRMED]
      .includes(this.#status.value);
  }

  getItemCount() {
    return this.#items.reduce((sum, item) => sum + item.quantity, 0);
  }

  #calculateTotal() {
    return this.#subtotal
      .add(this.#shippingCost)
      .subtract(this.#discount);
  }

  static #generateOrderNumber() {
    const timestamp = Date.now().toString(36).toUpperCase();
    const random = Math.random().toString(36).substring(2, 6).toUpperCase();
    return `ORD-${timestamp}-${random}`;
  }

  toJSON() {
    return {
      id: this.#id,
      order_number: this.#orderNumber,
      customer_id: this.#customerId,
      items: this.#items,
      status: this.#status.value,
      subtotal: this.#subtotal.value,
      shipping_cost: this.#shippingCost.value,
      discount: this.#discount.value,
      total: this.#total.value,
      shipping_address: this.#shippingAddress,
      notes: this.#notes,
      created_at: this.#createdAt,
      updated_at: this.#updatedAt,
    };
  }
}

module.exports = Order;

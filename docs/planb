// server/src/domain/value-objects/Address.js

class Address {
  constructor({ city, area, street, building, floor, apartment, notes }) {
    if (!city || !city.trim()) {
      throw new Error('المدينة مطلوبة');
    }

    this.city = city.trim();
    this.area = area?.trim() || '';
    this.street = street?.trim() || '';
    this.building = building?.trim() || '';
    this.floor = floor?.trim() || '';
    this.apartment = apartment?.trim() || '';
    this.notes = notes?.trim() || '';

    Object.freeze(this);
  }

  format() {
    const parts = [
      this.city,
      this.area,
      this.street,
      this.building,
    ].filter(Boolean);
    return parts.join('، ');
  }

  toJSON() {
    return {
      city: this.city,
      area: this.area,
      street: this.street,
      building: this.building,
      floor: this.floor,
      apartment: this.apartment,
      notes: this.notes,
    };
  }
}

module.exports = Address;

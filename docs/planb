const fs = require('fs');
const path = require('path');

class MigrationRunner {
  #pool;
  #migrationsPath;

  constructor(pool) {
    this.#pool = pool;
    this.#migrationsPath = path.join(__dirname);
  }

  async run() {
    // إنشاء جدول التتبع
    await this.#pool.query(`
      CREATE TABLE IF NOT EXISTS _migrations (
        id SERIAL PRIMARY KEY,
        name VARCHAR(255) NOT NULL UNIQUE,
        executed_at TIMESTAMP DEFAULT NOW()
      )
    `);

    // جلب المنفذة
    const { rows: executed } = await this.#pool.query(
      'SELECT name FROM _migrations ORDER BY id'
    );
    const executedNames = new Set(executed.map(r => r.name));

    // جلب ملفات SQL
    const files = fs.readdirSync(this.#migrationsPath)
      .filter(f => f.endsWith('.sql'))
      .sort();

    let count = 0;
    for (const file of files) {
      if (executedNames.has(file)) continue;

      console.log(`🔄 تنفيذ migration: ${file}`);

      const sql = fs.readFileSync(
        path.join(this.#migrationsPath, file),
        'utf8'
      );

      const client = await this.#pool.connect();
      try {
        await client.query('BEGIN');
        await client.query(sql);
        await client.query(
          'INSERT INTO _migrations (name) VALUES ($1)',
          [file]
        );
        await client.query('COMMIT');
        count++;
        console.log(`✅ تم تنفيذ: ${file}`);
      } catch (error) {
        await client.query('ROLLBACK');
        throw new Error(`فشل في migration ${file}: ${error.message}`);
      } finally {
        client.release();
      }
    }

    console.log(
      count > 0
        ? `✅ تم تنفيذ ${count} migration(s)`
        : '✅ قاعدة البيانات محدّثة'
    );
  }
}

module.exports = MigrationRunner;

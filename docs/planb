```javascript
// server/src/domain/value-objects/Slug.js

class Slug {
  #value;

  constructor(value) {
    if (!value || typeof value !== 'string') {
      throw new Error('الرابط المختصر مطلوب');
    }

    this.#value = Slug.#generate(value);
  }

  static fromText(text) {
    return new Slug(text);
  }

  get value() {
    return this.#value;
  }

  static #generate(text) {
    return text
      .toString()
      .toLowerCase()
      .trim()
      .replace(/\s+/g, '-')
      .replace(/[^\u0621-\u064Aa-z0-9\-]/g, '')
      .replace(/\-\-+/g, '-')
      .replace(/^-+/, '')
      .replace(/-+$/, '');
  }

  equals(other) {
    return other instanceof Slug && this.#value === other.#value;
  }

  toString() {
    return this.#value;
  }
}

module.exports = Slug;
```


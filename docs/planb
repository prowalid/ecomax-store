// server/src/domain/value-objects/Phone.js

class Phone {
  #value;

  constructor(value) {
    if (!value || typeof value !== 'string') {
      throw new Error('رقم الهاتف مطلوب');
    }

    // تنظيف الرقم
    const cleaned = value.replace(/[\s\-\(\)]/g, '');

    // التحقق من الصيغة
    if (!/^\+?\d{9,15}$/.test(cleaned)) {
      throw new Error('صيغة رقم الهاتف غير صالحة');
    }

    this.#value = cleaned;
  }

  get value() {
    return this.#value;
  }

  // تحويل لصيغة WhatsApp
  toWhatsApp() {
    const num = this.#value.startsWith('+')
      ? this.#value.slice(1)
      : this.#value;
    return num;
  }

  equals(other) {
    return other instanceof Phone && this.#value === other.#value;
  }

  toString() {
    return this.#value;
  }
}

module.exports = Phone;

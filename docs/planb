```javascript
// server/src/application/use-cases/orders/CreateOrder.js

const Order = require('../../../domain/entities/Order');
const Customer = require('../../../domain/entities/Customer');
const OrderCreated = require('../../../domain/events/OrderCreated');
const NotFoundError = require('../../../domain/errors/NotFoundError');
const InsufficientStockError = require('../../../domain/errors/InsufficientStockError');

class CreateOrder {
  #orderRepo;
  #productRepo;
  #customerRepo;
  #cartRepo;
  #eventBus;

  constructor({ orderRepository, productRepository, customerRepository, cartRepository, eventBus }) {
    this.#orderRepo = orderRepository;
    this.#productRepo = productRepository;
    this.#customerRepo = customerRepository;
    this.#cartRepo = cartRepository;
    this.#eventBus = eventBus;
  }

  async execute({ customerData, items, shippingAddress, notes, sessionId }) {
    // 1. التحقق من المنتجات والمخزون
    const orderItems = [];
    let subtotal = 0;

    for (const item of items) {
      const product = await this.#productRepo.findById(item.productId);

      if (!product) {
        throw new NotFoundError('المنتج', item.productId);
      }

      if (!product.isActive) {
        throw new Error(`المنتج "${product.name}" غير متاح حالياً`);
      }

      if (!product.hasEnoughStock(item.quantity)) {
        throw new InsufficientStockError(
          product.name, item.quantity, product.stock
        );
      }

      const itemTotal = product.price.value * item.quantity;
      subtotal += itemTotal;

      orderItems.push({
        productId: product.id,
        productName: product.name,
        price: product.price.value,
        quantity: item.quantity,
        total: itemTotal,
      });
    }

    // 2. إنشاء أو جلب العميل
    let customer;
    const existingCustomer = await this.#customerRepo
      .findByPhone(customerData.phone);

    if (existingCustomer) {
      customer = existingCustomer;
    } else {
      customer = new Customer({
        name: customerData.name,
        phone: customerData.phone,
        email: customerData.email || null,
        address: shippingAddress,
      });
      customer = await this.#customerRepo.save(customer);
    }

    // 3. إنشاء الطلب
    const order = new Order({
      customerId: customer.id,
      items: orderItems,
      subtotal,
      shippingCost: 0, // سيتم حسابه لاحقاً حسب الإعدادات
      discount: 0,
      shippingAddress,
      notes,
    });

    const savedOrder = await this.#orderRepo.save(order);

    // 4. تحديث المخزون
    for (const item of items) {
      const product = await this.#productRepo.findById(item.productId);
      product.decreaseStock(item.quantity);
      await this.#productRepo.save(product);
    }

    // 5. تنظيف السلة
    if (sessionId) {
      await this.#cartRepo.clear(sessionId);
    }

    // 6. تسجيل الطلب لدى العميل
    customer.recordOrder(savedOrder.total.value);
    await this.#customerRepo.save(customer);

    // 7. نشر الحدث ✅
    await this.#eventBus.publish(new OrderCreated(savedOrder, customer));

    return savedOrder;
  }
}

module.exports = CreateOrder;
```


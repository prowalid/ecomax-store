class EventBus {
  #handlers = new Map();
  #queue;

  constructor(queueManager) {
    this.#queue = queueManager;
  }

  subscribe(eventName, handler) {
    if (!this.#handlers.has(eventName)) {
      this.#handlers.set(eventName, []);
    }
    this.#handlers.get(eventName).push(handler);
  }

  async publish(event) {
    const handlers = this.#handlers.get(event.name) || [];

    // تنفيذ المعالجات المتزامنة
    for (const handler of handlers) {
      try {
        await handler(event);
      } catch (error) {
        console.error(
          `خطأ في معالجة الحدث ${event.name}:`,
          error.message
        );
        // لا نوقف العملية بسبب فشل معالج حدث
      }
    }

    // إضافة للـ Queue للعمليات الثقيلة
    if (this.#queue) {
      await this.#queue.addJob(event.name, event.payload);
    }
  }
}

module.exports = EventBus;

```javascript
// server/src/domain/value-objects/OrderStatus.js

class OrderStatus {
  static PENDING = 'pending';
  static CONFIRMED = 'confirmed';
  static PROCESSING = 'processing';
  static SHIPPED = 'shipped';
  static DELIVERED = 'delivered';
  static CANCELLED = 'cancelled';
  static RETURNED = 'returned';

  // ✅ خريطة الانتقالات المسموحة
  static #transitions = {
    [OrderStatus.PENDING]:    [OrderStatus.CONFIRMED, OrderStatus.CANCELLED],
    [OrderStatus.CONFIRMED]:  [OrderStatus.PROCESSING, OrderStatus.CANCELLED],
    [OrderStatus.PROCESSING]: [OrderStatus.SHIPPED, OrderStatus.CANCELLED],
    [OrderStatus.SHIPPED]:    [OrderStatus.DELIVERED, OrderStatus.RETURNED],
    [OrderStatus.DELIVERED]:  [OrderStatus.RETURNED],
    [OrderStatus.CANCELLED]:  [],
    [OrderStatus.RETURNED]:   [],
  };

  #value;

  constructor(value) {
    const allStatuses = Object.values(OrderStatus)
      .filter(v => typeof v === 'string');

    if (!allStatuses.includes(value)) {
      throw new Error(`حالة الطلب غير معروفة: ${value}`);
    }

    this.#value = value;
  }

  get value() {
    return this.#value;
  }

  canTransitionTo(newStatus) {
    const allowed = OrderStatus.#transitions[this.#value] || [];
    return allowed.includes(
      newStatus instanceof OrderStatus ? newStatus.value : newStatus
    );
  }

  transitionTo(newStatusValue) {
    if (!this.canTransitionTo(newStatusValue)) {
      throw new Error(
        `لا يمكن تغيير حالة الطلب من "${this.#value}" إلى "${newStatusValue}"`
      );
    }
    return new OrderStatus(newStatusValue);
  }

  isFinal() {
    return [OrderStatus.CANCELLED, OrderStatus.RETURNED, OrderStatus.DELIVERED]
      .includes(this.#value);
  }

  equals(other) {
    return other instanceof OrderStatus && this.#value === other.#value;
  }

  toString() {
    return this.#value;
  }
}

module.exports = OrderStatus;

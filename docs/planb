  #compareAtPrice;
  #cost;
  #sku;
  #stock;
  #trackStock;
  #categoryId;
  #images;
  #isActive;
  #createdAt;
  #updatedAt;

  constructor({
    id,
    name,
    slug,
    description,
    price,
    compareAtPrice,
    cost,
    sku,
    stock,
    trackStock,
    categoryId,
    images,
    isActive,
    createdAt,
    updatedAt,
  }) {
    // ✅ التحقق على مستوى الدومين
    if (!name || name.trim().length < 2) {
      throw new Error('اسم المنتج يجب أن يكون حرفين على الأقل');
    }

    this.#id = id || null;
    this.#name = name.trim();
    this.#slug = slug;
    this.#description = description || '';
    this.#price = price instanceof Money ? price : new Money(price);
    this.#compareAtPrice = compareAtPrice
      ? (compareAtPrice instanceof Money ? compareAtPrice : new Money(compareAtPrice))
      : null;
    this.#cost = cost
      ? (cost instanceof Money ? cost : new Money(cost))
      : null;
    this.#sku = sku || null;
    this.#stock = typeof stock === 'number' ? stock : 0;
    this.#trackStock = trackStock !== false;
    this.#categoryId = categoryId || null;
    this.#images = images || [];
    this.#isActive = isActive !== false;
    this.#createdAt = createdAt || new Date();
    this.#updatedAt = updatedAt || new Date();
  }

  // Getters
  get id() { return this.#id; }
  get name() { return this.#name; }
  get slug() { return this.#slug; }
  get description() { return this.#description; }
  get price() { return this.#price; }
  get compareAtPrice() { return this.#compareAtPrice; }
  get cost() { return this.#cost; }
  get sku() { return this.#sku; }
  get stock() { return this.#stock; }
  get trackStock() { return this.#trackStock; }
  get categoryId() { return this.#categoryId; }
  get images() { return [...this.#images]; }
  get isActive() { return this.#isActive; }
  get createdAt() { return this.#createdAt; }
  get updatedAt() { return this.#updatedAt; }

  // ✅ سلوكيات الدومين (Business Logic)

  isInStock() {
    if (!this.#trackStock) return true;
    return this.#stock > 0;
  }

  hasEnoughStock(quantity) {
    if (!this.#trackStock) return true;
    return this.#stock >= quantity;
  }

  decreaseStock(quantity) {
    if (!this.#trackStock) return;

    if (quantity <= 0) {
      throw new Error('الكمية يجب أن تكون أكبر من صفر');
    }

    if (!this.hasEnoughStock(quantity)) {
      throw new Error(
        `الكمية المطلوبة (${quantity}) أكبر من المتوفر (${this.#stock}) للمنتج "${this.#name}"`
      );
    }

    this.#stock -= quantity;
    this.#updatedAt = new Date();
  }

  increaseStock(quantity) {
    if (!this.#trackStock) return;

    if (quantity <= 0) {
      throw new Error('الكمية يجب أن تكون أكبر من صفر');
    }

    this.#stock += quantity;
    this.#updatedAt = new Date();
  }

  hasDiscount() {
    return this.#compareAtPrice !== null
      && this.#compareAtPrice.value > this.#price.value;
  }

  getDiscountPercentage() {
    if (!this.hasDiscount()) return 0;
    return Math.round(
      (1 - this.#price.value / this.#compareAtPrice.value) * 100
    );
  }

  getProfit() {
    if (!this.#cost) return null;
    return this.#price.subtract(this.#cost);
  }

  activate() {
    this.#isActive = true;
    this.#updatedAt = new Date();
  }

  deactivate() {
    this.#isActive = false;
    this.#updatedAt = new Date();
  }

  updateDetails({ name, description, price, compareAtPrice, cost, sku, categoryId }) {
    if (name !== undefined) {
      if (!name || name.trim().length < 2) {
        throw new Error('اسم المنتج يجب أن يكون حرفين على الأقل');
      }
      this.#name = name.trim();
    }

    if (description !== undefined) this.#description = description;
    if (price !== undefined) this.#price = new Money(price);
    if (compareAtPrice !== undefined) {
      this.#compareAtPrice = compareAtPrice ? new Money(compareAtPrice) : null;
    }
    if (cost !== undefined) this.#cost = cost ? new Money(cost) : null;
    if (sku !== undefined) this.#sku = sku;
    if (categoryId !== undefined) this.#categoryId = categoryId;

    this.#updatedAt = new Date();
  }

  // تحويل للتخزين
  toJSON() {
    return {
      id: this.#id,
      name: this.#name,
      slug: this.#slug,
      description: this.#description,
      price: this.#price.value,
      compare_at_price: this.#compareAtPrice?.value || null,
      cost: this.#cost?.value || null,
      sku: this.#sku,
      stock: this.#stock,
      track_stock: this.#trackStock,
      category_id: this.#categoryId,
      images: this.#images,
      is_active: this.#isActive,
      created_at: this.#createdAt,
      updated_at: this.#updatedAt,
    };
  }
}

module.exports = Product;

// server/src/index.js

const createApp = require('./app');
const createContainer = require('./container');
const MigrationRunner = require('./infrastructure/database/migrations/runner');

async function main() {
  try {
    // 1. إنشاء الحاوية
    const container = createContainer();

    // 2. تشغيل الترحيلات
    const pool = container.resolve('pool');
    const migrator = new MigrationRunner(pool);
    await migrator.run();

    // 3. إنشاء التطبيق
    const app = createApp(container);

    // 4. تشغيل الخادم
    const PORT = process.env.PORT || 3000;
    const server = app.listen(PORT, () => {
      console.log(`🚀 الخادم يعمل على المنفذ ${PORT}`);
    });

    // 5. إغلاق نظيف
    const shutdown = async (signal) => {
      console.log(`\n📴 ${signal} - جارٍ الإغلاق...`);
      server.close(async () => {
        await container.shutdown();
        console.log('✅ تم الإغلاق بنجاح');
        process.exit(0);
      });

      // إغلاق إجباري بعد 10 ثوانٍ
      setTimeout(() => {
        console.error('⚠️ إغلاق إجباري');
        process.exit(1);
      }, 10000);
    };

    process.on('SIGTERM', () => shutdown('SIGTERM'));
    process.on('SIGINT', () => shutdown('SIGINT'));

  } catch (error) {
    console.error('❌ فشل في تشغيل الخادم:', error);
    process.exit(1);
  }
}

main();
